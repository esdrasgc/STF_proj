MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=example
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=stf_data

# Celery (RabbitMQ broker) and results backend (MongoDB)
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=mongodb://root:example@mongo:27017/celery_results?authSource=admin

# Redis for rate limiting
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Rate limiting configuration
MAX_REQUESTS_PER_MINUTE=30
MIN_DELAY_PROCESSO=2.0
MAX_DELAY_PROCESSO=5.0
MIN_DELAY_ABA=1.0
MAX_DELAY_ABA=3.0
RETRY_COUNTDOWN_SECONDS=300
MAX_RETRIES=5
REQUEST_TIMEOUT=13
RATE_LIMITER_MAX_WAIT=300

# Celery worker control
WORKER_CONCURRENCY=2
WORKER_PREFETCH_MULTIPLIER=1
